// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Rappresenta il tipo di contratto di un annuncio (vendita o affitto).
enum TipoContratto {
  VENDITA
  AFFITTO
}

/// Identifica se l'annuncio riguarda un immobile residenziale/commerciale classico (B2C) o un'attività/business (B2B).
enum CategoriaListing {
  IMMOBILE
  BUSINESS
}

/// Rappresenta lo stato attuale del contatto generato (Lead).
enum LeadStatus {
  NEW          // Nuovo contatto non ancora preso in carico
  IN_PROGRESS  // In fase di gestione/contatto in corso
  CONTACTED    // Contatto stabilito con successo
  CLOSED       // Lead chiuso/risolto con successo
  CANCELLED    // Contatto archiviato o non interessato
}

/// Modello principale che rappresenta un annuncio generico inserito nel portale.
/// Funge da entità base sia per immobili residenziali/commerciali standard (B2C)
/// sia per la cessione di rami d'azienda o attività commerciali (B2B).
model Listing {
  id              Int              @id @default(autoincrement())
  titolo          String           @db.VarChar(255)
  descrizione     String           @db.Text
  
  // Utilizziamo Decimal per i prezzi per evitare problemi di arrotondamento dei numeri a virgola mobile.
  prezzo          Decimal          @db.Decimal(12, 2)
  indirizzo       String           @db.VarChar(255)
  
  // Enum per garantire l'integrità del tipo di contratto d'annuncio.
  tipo_contratto  TipoContratto
  
  // Enum per distinguere gli annunci immobiliari privati da quelli aziendali/servizi commerciali.
  categoria       CategoriaListing
  
  // Le immagini vengono salvate come array in formato JSON (stringhe URL), dato che MySQL supporta nativamente il tipo JSON
  // e Prisma non supporta direttamente array di scalari (es. String[]) sui database relazionali come MySQL.
  immagini        Json
  
  data_creazione  DateTime         @default(now())

  // Campi Getrix e gestionali Studio BP Italia aggiuntivi
  riferimento           String?          @db.VarChar(50)
  getrix_id             String?          @db.VarChar(50)
  comune                String?          @db.VarChar(100)
  zona                  String?          @db.VarChar(100)
  tipologia             String?          @db.VarChar(100)
  stato_immobile        String?          @db.VarChar(100)
  riscaldamento         String?          @db.VarChar(100)
  anno_costruzione      String?          @db.VarChar(10)
  disponibilita         String?          @db.VarChar(100)
  spese_condominiali    String?          @db.VarChar(100)
  provvigione           String?          @db.VarChar(100)
  tassazione            String?          @db.VarChar(100)
  proprietario_nome     String?          @db.VarChar(150)
  proprietario_telefono String?          @db.VarChar(50)
  stima_riservata       Decimal?         @db.Decimal(12, 2)

  // Relazione 1-a-1 opzionale con PropertyDetails. Se categoria = IMMOBILE, questa relazione conterrà i dettagli fisici del bene.
  propertyDetails PropertyDetails?

  // Relazione 1-a-1 opzionale con BusinessDetails. Se categoria = BUSINESS, questa relazione conterrà i dati del business.
  businessDetails BusinessDetails?

  // Relazione 1-a-Molti con i Lead contatti generati da questo specifico annuncio.
  leads           Lead[]

  @@map("listings")
}

/// Modello relazionato 1-a-1 a Listing. Contiene le caratteristiche specifiche dei beni
/// immobiliari residenziali o commerciali classici (mercato B2C di Studio BP Italia).
model PropertyDetails {
  id                 Int      @id @default(autoincrement())
  
  // Chiave esterna unica per definire la relazione 1-to-1 con Listing.
  listingId          Int      @unique @map("listing_id")
  listing            Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  mq                 Int      // Superficie in metri quadri.
  stanze             Int      // Numero di vani/camere.
  bagni              Int      // Numero di servizi igienici.
  
  classe_energetica  String   @db.VarChar(10) // E.g., "A4", "B", "G".
  
  piano              String?  @db.VarChar(50) // Stringa opzionale per gestire piani complessi (es. "Rialzato", "3° con ascensore", "Piano Terra").
  
  posto_auto         Boolean  @default(false)
  giardino           Boolean  @default(false)

  @@map("property_details")
}

/// Modello relazionato 1-a-1 a Listing. Racchiude i dettagli finanziari, patrimoniali e lavorativi
/// specifici per la cessione di attività commerciali o rami d'azienda (mercato B2B di Studio BP Italia).
model BusinessDetails {
  id                  Int      @id @default(autoincrement())
  
  // Chiave esterna unica per definire la relazione 1-to-1 con Listing.
  listingId           Int      @unique @map("listing_id")
  listing             Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  settore_merceologico String   @db.VarChar(100) // E.g., "Ristorazione", "Logistica", "Hotellerie".
  
  // I campi finanziari opzionali utilizzano Decimal per garantire l'accuratezza contabile.
  fatturato_annuo     Decimal? @db.Decimal(15, 2)
  canone_mura         Decimal? @db.Decimal(12, 2) // Canone di locazione mensile o annuo per le mura commerciali.
  utile_netto         Decimal? @db.Decimal(15, 2)
  
  numero_dipendenti   Int?     @default(0)

  @@map("business_details")
}

/// Modello per memorizzare i contatti (leads) ed espletare il funnel di conversione
/// sia per potenziali acquirenti/affittuari di immobili che per imprenditori interessati ai business.
model Lead {
  id                     Int        @id @default(autoincrement())
  nome                   String     @db.VarChar(150)
  email                  String     @db.VarChar(150)
  telefono               String?    @db.VarChar(30)
  messaggio              String     @db.Text
  
  // Chiave esterna opzionale: un lead può nascere da un annuncio specifico, oppure essere un contatto generico.
  id_listing_associato   Int?       @map("id_listing_associato")
  listing                Listing?   @relation(fields: [id_listing_associato], references: [id], onDelete: SetNull)

  // Enum o stringa validata per lo stato di avanzamento del lead.
  status                 LeadStatus @default(NEW)
  
  data_creazione         DateTime   @default(now())

  @@map("leads")
}

// ==========================================
// Modelli dell'app Contabilità (condivisi nel medesimo database)
// ==========================================

model Setting {
  key   String  @id @db.VarChar(255)
  value String? @db.Text

  @@map("settings")
}

model Account {
  id      String  @id @db.VarChar(255)
  name    String  @db.VarChar(255)
  type    String  @db.VarChar(255)
  scope   String  @db.VarChar(255)
  balance Float   @db.Double
  limit   Float?  @db.Double
  iban    String? @db.VarChar(255)
  notes   String? @db.Text
  isDemo  Boolean @default(false)

  transactions Transaction[]
  recurringTransactions RecurringTransaction[]

  @@map("accounts")
}

model Transaction {
  id                   String  @id @db.VarChar(255)
  date                 String  @db.VarChar(255)
  description          String  @db.Text
  amount               Float   @db.Double
  type                 String  @db.VarChar(255)
  accountId            String  @db.VarChar(255)
  destinationAccountId String? @db.VarChar(255)
  scope                String  @db.VarChar(255)
  category             String  @db.VarChar(255)
  subcategory          String  @db.VarChar(255)
  isAutoMatched        Boolean @default(false)
  ruleId               String? @db.VarChar(255)
  isVerified           Boolean @default(false)
  isDemo               Boolean @default(false)
  linkedTransactionId  String? @db.VarChar(255)
  notes                String? @db.Text
  customer             String? @db.VarChar(255)
  invoiceId            String? @db.VarChar(255)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("transactions")
  @@index([accountId])
  @@index([date])
}

model Rule {
  id                   String  @id @db.VarChar(255)
  name                 String  @db.VarChar(255)
  keyword              String  @db.VarChar(255)
  scope                String  @db.VarChar(255)
  category             String  @db.VarChar(255)
  subcategory          String  @db.VarChar(255)
  accountId            String? @db.VarChar(255)
  destinationAccountId String? @db.VarChar(255)
  isDemo               Boolean @default(false)

  @@map("rules")
}

model RecurringTransaction {
  id                   String   @id @db.VarChar(255)
  name                 String   @db.VarChar(255)
  keyword              String   @db.VarChar(255)
  amount               Float    @db.Double
  frequency            String   @db.VarChar(255)
  scope                String   @db.VarChar(255)
  category             String   @db.VarChar(255)
  subcategory          String   @db.VarChar(255)
  accountId            String   @db.VarChar(255)
  destinationAccountId String?  @db.VarChar(255)
  nextDueDate          String   @db.VarChar(255)
  isActive             Boolean  @default(true)
  isDemo               Boolean  @default(false)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("recurring_transactions")
  @@index([accountId])
}
